# ============================================================================
# SEMSE OS - production environment template
# Use the sections below per Railway service. Do not load this file wholesale
# into every service without trimming it to the variables that service needs.
# ============================================================================

# ============================================================================
# Shared secrets - set the same values on API, Web and Worker
# ============================================================================
NODE_ENV=production
AUTH_SECRET=replace-with-a-64-char-secret-shared-by-api-web-worker
SEMSE_BOOTSTRAP_TOKEN=replace-with-a-second-shared-secret-for-internal-token-bootstrap

# Optional: override the web session signing key instead of reusing AUTH_SECRET.
# Leave blank to let the web service reuse AUTH_SECRET.
SEMSE_WEB_SESSION_SECRET=

# ============================================================================
# API service
# Public domain example: https://api.semseproject.com
# Add a Railway volume mounted at /data for persistent file storage.
# ============================================================================
PORT=4000
HOST=::
DATABASE_URL=postgresql://...
REDIS_URL=redis://...
CORS_ORIGINS=https://app.semseproject.com,https://semseproject.com
SEMSE_API_BASE_URL=https://api.semseproject.com
SEMSE_WEB_BASE_URL=https://app.semseproject.com
SEMSE_DEMO_MODE=false

STORAGE_PROVIDER=local
SEMSE_STORAGE_ROOT=/data/semse-storage
SEMSE_MULTIPART_STORAGE_ROOT=/data/semse-storage/multipart

RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=20

# LLM routing
ENABLE_LLM_ROUTER=true
LLM_DEFAULT_PROVIDER=anthropic
LLM_FALLBACK_PROVIDERS=anthropic,openai,template

# Providers
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=kimi-k2

# Optional local/open models
ENABLE_OPEN_SOURCE_MODELS=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Optional production integrations
STRIPE_SECRET_KEY=
STRIPE_CONNECT_ACCOUNT_ID=
SEMSE_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
GITHUB_TOKEN=
GITHUB_API_BASE_URL=
REPO_NAME=
SEMSE_AUTONOMY_REPO_PATH=/app
SEMSE_AUTONOMY_BASE_BRANCH=main
SEMSE_AUTONOMY_LOCAL_PR_MODE=false
SEMSE_AUTONOMY_GITHUB_TOKEN=
SEMSE_AUTONOMY_REPO_NAME=
SEMSE_AUTONOMY_LLM_PROVIDER=
SEMSE_AUTONOMY_LLM_API_KEY=
SEMSE_AUTONOMY_LLM_MODEL=
SEMSE_AUTONOMY_LLM_BASE_URL=
SEMSE_AUTONOMY_OPENAI_API_KEY=
SEMSE_AUTONOMY_OPENAI_MODEL=
SEMSE_AUTONOMY_OPENAI_BASE_URL=
SEMSE_RUNTIME_MODE=live

# ============================================================================
# Web service
# Internal API URL example on Railway:
#   http://semse-api.railway.internal:4000
# Public domain example: https://app.semseproject.com
# ============================================================================
PORT=3000
HOSTNAME=0.0.0.0
SEMSE_API_BASE_URL=http://semse-api.railway.internal:4000
NEXT_PUBLIC_SEMSE_RUNTIME_ENABLED=true
NEXT_PUBLIC_SEMSE_DEMO_LOGIN_ENABLED=false

# Fallback server identity used by server-side pages and public preview routes.
# Replace with your real tenant/org/user once Block B onboarding is complete.
SEMSE_TENANT_ID=tenant_default
SEMSE_ORG_ID=org_admin_001
SEMSE_USER_ID=usr_admin_001
SEMSE_ROLES=OPS_ADMIN

# ============================================================================
# Worker service
# Internal API URL example on Railway:
#   http://semse-api.railway.internal:4000
# ============================================================================
SEMSE_API_URL=http://semse-api.railway.internal:4000
REDIS_URL=redis://...
SEMSE_WORKER_ID=worker-primary
SEMSE_TENANT_ID=tenant_default
SEMSE_ORG_ID=org_admin_001
SEMSE_USER_ID=usr_admin_001
SEMSE_ROLES=OPS_ADMIN,WORKER
SEMSE_HEARTBEAT_MS=2500
SEMSE_RUN_SIM_MS=4000
SEMSE_FAIL_RATE=0
SEMSE_RECLAIM_MS=10000
SEMSE_STALE_AFTER_MS=10000
SEMSE_AGENT_TYPE=
