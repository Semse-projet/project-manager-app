{
  "name": "@semse/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma db push --skip-generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node --experimental-strip-types prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "prisma:repair-soft-delete": "node --experimental-strip-types ./scripts/repair-soft-delete-drift.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "prisma": "^6.4.1"
  }
}
