  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, projectId])
  @@index([tenantId, priority])
  @@index([tenantId, templateKey])
  @@unique([projectId, templateKey])
}

/// Conversation session for the assistant flow.
