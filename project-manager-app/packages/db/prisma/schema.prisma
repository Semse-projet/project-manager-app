  tenantId         String
  orgId            String
  jobId            String?  @unique
  createdBy        String
  title            String
  description      String?
  trade            String
  projectType      String
  clientName       String
  professionalName String?
  location         String
  budgetEstimate   Decimal? @db.Decimal(12, 2)
  status           String   @default("draft")
  riskScore        Int      @default(0)
  riskLevel        String   @default("low")
  startDate        DateTime?
  dueDate          DateTime?
  sourceTool       String?
  sourceToolInput  Json?
  sourceToolResult Json?
  clientPlanApprovalStatus   String   @default("pending")
  clientPlanApprovedAt       DateTime?
  clientPlanApprovedById     String?
  clientPlanApprovalSource   String?
  clientPlanApprovalReason   String?
  clientPlanReviewedAt       DateTime?
  clientPlanReviewComment    String?
  clientPlanUnapprovedAt     DateTime?
