  milestoneId   String
  label         String
  description   String?
  kind          String    @default("PHOTO")     // PHOTO | VIDEO | DOCUMENT
  phase         String    @default("after")     // before | during | after
  required      Boolean   @default(true)
  status        String    @default("missing")   // missing | submitted | approved | rejected
  evidenceId    String?
  reviewNote    String?
  reviewedById  String?
  reviewedAt    DateTime?
  milestone     Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
