  @@index([farmId])
}

model AgroAnimal {
  id                  String    @id @default(cuid())
  farmId              String
  farm                AgroFarm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  currentUnitId       String?
  currentUnit         AgroFarmUnit? @relation(fields: [currentUnitId], references: [id])
  tagCode             String?
  species             String    // CATTLE | PIG | GOAT | SHEEP | HORSE | CHICKEN | OTHER
  breed               String?
  sex                 String    @default("UNKNOWN") // MALE | FEMALE | UNKNOWN
  birthDate           DateTime?
  estimatedAgeMonths  Int?
  initialWeight       Decimal?  @db.Decimal(10, 2)
  currentWeight       Decimal?  @db.Decimal(10, 2)
  status              String    @default("ACTIVE") // ACTIVE | SOLD | DEAD | LOST | INACTIVE
  acquisitionDate     DateTime?
  acquisitionCost     Decimal?  @db.Decimal(12, 2)
  purpose             String    @default("OTHER") // FATTENING | DAIRY | BREEDING | GENETICS | LAYING | RESALE | WORK | OTHER
  estimatedValue      Decimal?  @db.Decimal(12, 2)
  expectedSalePrice   Decimal?  @db.Decimal(12, 2)
  expectedSaleDate    DateTime?
  notes               String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([farmId])
  @@index([currentUnitId])
  @@index([status])
  @@index([species])
}

model AgroAnimalGroup {
  id               String    @id @default(cuid())
  farmId           String
  farm             AgroFarm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  currentUnitId    String?
  currentUnit      AgroFarmUnit? @relation(fields: [currentUnitId], references: [id])
