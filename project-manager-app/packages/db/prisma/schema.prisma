  inputJson          Json      @default("{}")
  outputJson         Json      @default("{}")
  confidenceScore    Int?
  riskScore          Int?
  readinessScore     Int?
  disputeRiskScore   Int?
  priceBandLow       Decimal?  @db.Decimal(12, 2)
  priceBandMid       Decimal?  @db.Decimal(12, 2)
  priceBandHigh      Decimal?  @db.Decimal(12, 2)
  canPublish         Boolean   @default(true)
  canCreateBuildOps  Boolean   @default(false)
  canCreateContract  Boolean   @default(false)
