// ── Operational Intelligence ─────────────────────────────────────────────────

/// Operational signal emitted by intelligence agents when a condition is detected.
model OperationalSignal {
  id                String    @id @default(cuid())
  tenantId          String
  type              String                          // EVIDENCE_GAP | PAYMENT_BLOCKED | LOW_CONFIDENCE_ESTIMATE | CHANGE_ORDER_RECOMMENDED | DISPUTE_RISK_HIGH
  severity          String    @default("medium")   // low | medium | high | critical
  status            String    @default("open")     // open | acknowledged | resolved | dismissed
  title             String
  message           String
  recommendedAction String?
  sourceAgent       String?
  entityType        String
  entityId          String
  jobId             String?
  buildOpsProjectId String?
  milestoneId       String?
  metadataJson      Json?
  createdAt         DateTime  @default(now())
  acknowledgedAt    DateTime?
  resolvedAt        DateTime?

  @@index([tenantId, status])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([entityType, entityId])
  @@index([jobId])
  @@index([buildOpsProjectId])
  @@index([milestoneId])
  @@index([createdAt])
}

/// Traces each intelligence agent evaluation for auditability.
model IntelligenceRun {
  id                  String   @id @default(cuid())
  tenantId            String
  agentName           String
  triggerEvent        String
  entityType          String
  entityId            String
  contextSnapshotJson Json?
  decisionJson        Json?
  signalsCreated      String[] @default([])
  status              String   @default("completed") // completed | failed
  error               String?
  durationMs          Int?
  createdAt           DateTime @default(now())

  @@index([agentName])
  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

/// Caché de precios de materiales de construcción obtenidos de APIs externas (BLS PPI, FRED).
/// Se actualiza cada 24h mediante un worker job. Los engines ProTools leen de aquí.
model MaterialPriceSnapshot {
  id          String   @id @default(cuid())
  materialKey String   // Clave canónica, ej: "lumber-2x4", "steel-rebar", "copper-wire"
  blsSeriesId String?  // Código BLS PPI, ej: "WPU081" para lumber
  source      String   // "BLS_PPI" | "FRED" | "MANUAL"
  pricePerUnit Decimal @db.Decimal(10, 4)  // Precio por unidad canónica (USD)
  unit        String   // "board-ft", "ton", "sqft", "linear-ft", "each"
  indexValue  Decimal? @db.Decimal(10, 4)  // Índice PPI original (2012=100)
  basePrice   Decimal? @db.Decimal(10, 4)  // Precio base hardcoded de referencia
  changeYoY   Decimal? @db.Decimal(6, 4)   // Cambio año a año (%)
  fetchedAt   DateTime @default(now())
  validUntil  DateTime // Expiración del caché (default: fetchedAt + 24h)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([materialKey])
  @@index([materialKey])
  @@index([source])
  @@index([validUntil])
}

/// Caché de tarifas laborales reales por oficio de construcción.
/// Datos de BLS OEWS (Occupational Employment and Wage Statistics).
/// Se usa para derivar multiplicadores de labor por estado/metro.
model LaborRateSnapshot {
  id          String   @id @default(cuid())
  tradeKey    String   // "carpenter", "electrician", "plumber", etc.
  socCode     String   // BLS SOC code, e.g. "47-2031"
  scopeType   String   // "national" | state code "CA" | metro FIPS
  meanWage    Decimal  @db.Decimal(10, 2)  // Annual mean wage (USD)
  hourlyMean  Decimal  @db.Decimal(10, 2)  // Hourly mean wage (USD)
  multiplier  Decimal  @db.Decimal(6, 4)   // vs. national avg (1.00 = average)
  sampleSize  Int?                          // Employment estimate
  fetchedAt   DateTime @default(now())
  validUntil  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tradeKey, scopeType])
  @@index([tradeKey])
  @@index([scopeType])
  @@index([validUntil])
}

/// Índices de costo regional por estado (material + labor).
/// Combinación de factores RSMeans estáticos + OEWS dinámico.
model LocationCostIndex {
  id                  String   @id @default(cuid())
  stateCode           String   // "CA", "TX", "NY", etc.
  stateName           String
  materialMultiplier  Decimal  @db.Decimal(6, 4)  // vs. national avg
  laborMultiplier     Decimal  @db.Decimal(6, 4)  // vs. national avg
  dataSource          String   // "oews+static" | "manual"
  fetchedAt           DateTime @default(now())
  validUntil          DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([stateCode])
  @@index([stateCode])
  @@index([validUntil])
}

/// Calendario de deadlines de liens por proyecto y estado.
/// Integración con LienGrid API (50 estados US).
/// Un calendar por proyecto × estado combinación.
model LienCalendar {
  id                          String   @id @default(cuid())
  projectId                   String
  project                     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  stateName                   String   // "California", "Texas", "New York", etc.
  preliminaryNoticeDeadline   DateTime
  waiverDeadline              DateTime
  finalNoticeDeadline         DateTime?
  statusLienDeadline          DateTime?

  status                      String   @default("CREATED")  // CREATED | ALERTED_30D | ALERTED_7D | ALERTED_3D | NOTICE_SENT | NOTICE_DELIVERED | NOTICE_FAILED
  requiresNotary              Boolean  @default(false)
  requiresCertifiedMail       Boolean  @default(true)

  // Caché de integración
  liengridResponseJson        Json?    // Respuesta cruda de LienGrid API
  lastFetchedAt               DateTime?
  fetchRetryCount             Int      @default(0)

  notices                     LienNotice[]
  waivers                     LienWaiver[]

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([projectId, stateName])
  @@index([projectId])
  @@index([status])
  @@index([preliminaryNoticeDeadline])
}

/// Preliminary notice enviado vía Lob.com (correo certificado digital).
model LienNotice {
  id                          String   @id @default(cuid())
  lienCalendarId              String
  lienCalendar                LienCalendar @relation(fields: [lienCalendarId], references: [id], onDelete: Cascade)

  noticeType                  String   // "preliminary" | "final" | "status_lien"
  recipientType               String   // "owner" | "general_contractor" | "lender" | "architect"

  // Generación del notice
  generatedAt                 DateTime
  noticeContent               String   @db.Text  // HTML o plain text

  // Envío vía Lob.com
  sentVia                     String   // "certified_mail" | "email" | "manual"
  lobLetterTrackingId         String?  // ID de Lob para seguimiento
  lobLetterUrl                String?  // URL a PDF en CDN de Lob
  sentAt                      DateTime?

  // Seguimiento de entrega
  status                      String   @default("DRAFT")  // DRAFT | NOTICE_SENT | DELIVERY_PENDING | NOTICE_DELIVERED | DELIVERY_FAILED
  deliveredAt                 DateTime?

  // Audit
  createdBy                   String   // User ID
  sentBy                      String?  // User ID si envío manual

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([lienCalendarId])
  @@index([status])
  @@index([sentAt])
}

/// Waiver de lien condicional o incondicional.
/// Gate en FSM de Payments: no liberar escrow sin waiver firmado.
model LienWaiver {
  id                          String   @id @default(cuid())
  lienCalendarId              String
  lienCalendar                LienCalendar @relation(fields: [lienCalendarId], references: [id], onDelete: Cascade)

  escrowId                    String?  // Reference a PaymentEscrow si aplica
  milestoneId                 String?  // Reference a Milestone

  waiverType                  String   // "conditional" | "unconditional"
  releaseAmount               Decimal? @db.Decimal(15, 2)  // Null = unconditional (libera todo)

  status                      String   @default("PENDING")  // PENDING | SIGNED | REJECTED | EXPIRED

  // Firma digital
  signingUrl                  String?  // URL de firma digital (HelloSign/Dropbox Sign)
  signedAt                    DateTime?
  signature                   String?  @db.Text  // Base64 encoded signature image
  signedBy                    String?  // User ID (PRO contratista)

  // Expiration
  requiredBefore              DateTime // Fecha límite para firmar
  expiresAt                   DateTime? // Para waivers condicionales

  // Audit
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([lienCalendarId])
  @@index([status])
  @@index([requiredBefore])
}

// ─────────────────────────────────────────────────────────────────────────────
// SEMSE AGRO — F1 RanchOps Core
// ─────────────────────────────────────────────────────────────────────────────

model AgroFarm {
  id            String   @id @default(cuid())
  ownerId       String?
  name          String
  operationType String   @default("LIVESTOCK") // LIVESTOCK | MIXED | CROP
  locationLabel String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  units            AgroFarmUnit[]
  animals          AgroAnimal[]
  animalGroups     AgroAnimalGroup[]
  tasks            AgroFarmTask[]
  inventoryItems   AgroInventoryItem[]
  movements        AgroInventoryMovement[]
  costEntries      AgroCostEntry[]
  evidence         AgroEvidenceItem[]
  auditEvents      AgroAuditEvent[]
  productionCycles AgroProductionCycle[]
  cropCycles       AgroCropCycle[]
  inputApplications AgroInputApplication[]
  harvestRecords   AgroHarvestRecord[]
  traceability     AgroTraceabilityEvent[]
  complianceChecks AgroComplianceCheck[]
  productionRecords AgroProductionRecord[]
  saleRecords      AgroSaleRecord[]

