}

model AgroFarmUnit {
  id        String  @id @default(cuid())
  farmId    String
  farm      AgroFarm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name      String
  type      String  @default("OTHER") // PASTURE | CORRAL | BARN | STORAGE | WATER_SOURCE | WORK_AREA | FIELD | GREENHOUSE | OTHER
  areaValue Decimal? @db.Decimal(12, 4)
  areaUnit  String?  // SQFT | ACRE | HECTARE | MANZANA | OTHER
