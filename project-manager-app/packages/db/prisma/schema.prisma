  species          String    // CATTLE | PIG | GOAT | SHEEP | HORSE | CHICKEN | OTHER
  count            Int
  averageWeight    Decimal?  @db.Decimal(10, 2)
  status           String    @default("ACTIVE") // ACTIVE | SOLD | DEAD | LOST | INACTIVE
  acquisitionDate  DateTime?
  acquisitionCost  Decimal?  @db.Decimal(12, 2)
  purpose          String    @default("OTHER") // FATTENING | DAIRY | BREEDING | GENETICS | LAYING | RESALE | WORK | OTHER
  estimatedValue   Decimal?  @db.Decimal(12, 2)
  expectedSalePrice Decimal? @db.Decimal(12, 2)
  expectedSaleDate DateTime?
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([farmId])
  @@index([currentUnitId])
  @@index([status])
}

model AgroProductionRecord {
  id         String   @id @default(cuid())
  farmId     String
  farm       AgroFarm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  targetType String   // ANIMAL | ANIMAL_GROUP | FARM
  targetId   String?
  type       String   // MILK | EGGS | WEIGHT_GAIN | BIRTH | WOOL | HONEY | BREEDING_SERVICE | OTHER
  quantity   Decimal  @db.Decimal(12, 4)
  unit       String   // LITER | UNIT | DOZEN | LB | KG | HEAD | OTHER
  unitPrice  Decimal? @db.Decimal(12, 4)
  totalValue Decimal? @db.Decimal(14, 2)
  occurredAt DateTime
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([farmId])
  @@index([targetType, targetId])
  @@index([occurredAt])
  @@index([type])
}

model AgroSaleRecord {
  id             String   @id @default(cuid())
  farmId         String
  farm           AgroFarm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  targetType     String   // ANIMAL | ANIMAL_GROUP
  targetId       String
  buyerName      String?
  quantity       Int      @default(1)
  saleWeight     Decimal? @db.Decimal(10, 2)
  salePrice      Decimal  @db.Decimal(14, 2)
  freightCost    Decimal? @db.Decimal(12, 2)
  commission     Decimal? @db.Decimal(12, 2)
  paymentMethod  String?  // CASH | TRANSFER | CHECK | CREDIT | OTHER
  totalCostBasis Decimal? @db.Decimal(14, 2)
  netProfit      Decimal? @db.Decimal(14, 2)
  marginPercent  Decimal? @db.Decimal(8, 4)
  currency       String   @default("USD")
  occurredAt     DateTime
  notes          String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([farmId])
  @@index([targetType, targetId])
  @@index([occurredAt])
}

model AgroFarmTask {
  id           String    @id @default(cuid())
  farmId       String
  farm         AgroFarm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  targetType   String?   // ANIMAL | ANIMAL_GROUP | FARM_UNIT | INVENTORY | GENERAL
  targetId     String?
  assignedToId String?
  title        String
  type         String    // FEEDING | VACCINATION | TREATMENT | WEIGHING | MOVEMENT | CLEANING | INSPECTION | INVENTORY | SALE | WATER_CHECK | OTHER
  status       String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | BLOCKED | CANCELLED
  priority     String    @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  dueAt        DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  blockedAt    DateTime?
  cancelledAt  DateTime?
  blockReason  String?
  cancelReason String?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([farmId])
  @@index([status])
  @@index([assignedToId])
  @@index([dueAt])
}

model AgroInventoryItem {
  id           String    @id @default(cuid())
  farmId       String
  farm         AgroFarm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name         String
  category     String    // FEED | MEDICINE | VACCINE | FERTILIZER | SEED | FUEL | TOOL | MATERIAL | EQUIPMENT | OTHER
  unit         String    // UNIT | LB | KG | TON | LITER | GALLON | BAG | BOX | DOSE | BOTTLE | OTHER
  minimumStock Decimal?  @db.Decimal(12, 4)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  movements    AgroInventoryMovement[]

  @@index([farmId])
  @@index([category])
}

model AgroInventoryMovement {
  id              String    @id @default(cuid())
  farmId          String
  farm            AgroFarm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  itemId          String
  item            AgroInventoryItem @relation(fields: [itemId], references: [id])
  movementType    String    // IN | OUT | ADJUSTMENT
  quantity        Decimal?  @db.Decimal(12, 4)
  adjustmentDelta Decimal?  @db.Decimal(12, 4)
  unitCost        Decimal?  @db.Decimal(12, 4)
  totalCost       Decimal?  @db.Decimal(12, 4)
  relatedTaskId   String?   // polymorphic ref to AgroFarmTask.id
  targetType      String?
  targetId        String?
  occurredAt      DateTime
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())

  @@index([farmId])
  @@index([itemId])
  @@index([occurredAt])
}

model AgroCostEntry {
  id           String    @id @default(cuid())
  farmId       String
  farm         AgroFarm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  sourceType   String    // INVENTORY_MOVEMENT | TASK | MANUAL | SERVICE | EQUIPMENT | OTHER
  sourceId     String?   // polymorphic — ID of source entity (movement, task, etc.)
  targetType   String    // FARM | FARM_UNIT | ANIMAL | ANIMAL_GROUP | FARM_TASK | INVENTORY_ITEM | GENERAL
  targetId     String?
  category     String    // FEED | VETERINARY | LABOR | EQUIPMENT | TRANSPORT | INFRASTRUCTURE | SEED | FERTILIZER | FUEL | OTHER
  amount       Decimal   @db.Decimal(14, 2)
  currency     String    @default("USD")
  description  String?
  occurredAt   DateTime
  createdAt    DateTime  @default(now())

  @@index([farmId])
  @@index([occurredAt])
  @@index([targetType, targetId])
}

model AgroEvidenceItem {
  id            String    @id @default(cuid())
  farmId        String
  farm          AgroFarm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  entityType    String    // FARM | FARM_UNIT | ANIMAL | ANIMAL_GROUP | FARM_TASK | INVENTORY_ITEM | INVENTORY_MOVEMENT | COST_ENTRY | GENERAL
  entityId      String?
  mediaType     String    // NOTE | PHOTO | VIDEO | DOCUMENT | EXTERNAL_URL | OTHER
  title         String?
  note          String?   @db.Text
  fileUrl       String?
  capturedAt    DateTime
  capturedById  String?
  latitude      Decimal?  @db.Decimal(10, 7)
  longitude     Decimal?  @db.Decimal(10, 7)
  createdAt     DateTime  @default(now())

  @@index([farmId])
  @@index([entityType, entityId])
  @@index([capturedAt])
}

model AgroAuditEvent {
  id         String   @id @default(cuid())
  farmId     String
  farm       AgroFarm  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  actorId    String?
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  source     String   @default("SYSTEM") // WEB | MOBILE | SYNC | SYSTEM | IMPORT
  createdAt  DateTime @default(now())

  @@index([farmId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorId])
}

// ── Agro F2: Mixed FarmOps ────────────────────────────────────────────────────

model AgroProductionCycle {
  id            String    @id @default(cuid())
  farmId        String
  farm          AgroFarm  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name          String
  cycleType     String    // CATTLE_ROUND | CROP_SEASON | MIXED
  status        String    @default("ACTIVE") // ACTIVE | CLOSED | ARCHIVED
  startDate     DateTime
  endDate       DateTime?
  notes         String?
  metadataJson  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cropCycles    AgroCropCycle[]
  traceability  AgroTraceabilityEvent[]

  @@index([farmId, status])
}

model AgroCropCycle {
  id              String              @id @default(cuid())
  farmId          String
  farm            AgroFarm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  productionCycleId String?
  productionCycle AgroProductionCycle? @relation(fields: [productionCycleId], references: [id], onDelete: SetNull)
  cropName        String              // maíz | yuca | papa | pasto | etc.
  cropVariety     String?
  fieldUnitId     String?
  farmUnit        AgroFarmUnit?       @relation(fields: [fieldUnitId], references: [id], onDelete: SetNull)
  status          String              @default("PLANNED") // PLANNED | ACTIVE | HARVESTED | FAILED
  sowingDate      DateTime?
  expectedHarvestDate DateTime?
  actualHarvestDate   DateTime?
  areaHectares    Decimal?
  seedQuantityKg  Decimal?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  inputApplications AgroInputApplication[]
  harvestRecords    AgroHarvestRecord[]

  @@index([farmId, status])
}

model AgroInputApplication {
  id            String         @id @default(cuid())
  farmId        String
  farm          AgroFarm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  cropCycleId   String?
  cropCycle     AgroCropCycle? @relation(fields: [cropCycleId], references: [id], onDelete: SetNull)
  inventoryItemId String?
  inputType     String         // FERTILIZER | PESTICIDE | HERBICIDE | WATER | SEED | OTHER
  productName   String
  quantity      Decimal
  unit          String         // KG | L | GRAM | ML | DOSE
  appliedAt     DateTime
  appliedByUserId String?
  fieldUnitId   String?
  notes         String?
  createdAt     DateTime       @default(now())

  @@index([farmId])
  @@index([cropCycleId])
}

model AgroHarvestRecord {
  id              String         @id @default(cuid())
  farmId          String
  farm            AgroFarm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  cropCycleId     String?
  cropCycle       AgroCropCycle? @relation(fields: [cropCycleId], references: [id], onDelete: SetNull)
  harvestedAt     DateTime
  quantityKg      Decimal
  qualityGrade    String?        // A | B | C | REJECT
  storageLocation String?
  destinationType String?        // SALE | SELF_CONSUMPTION | SEED | LOSS
  notes           String?
  createdAt       DateTime       @default(now())

  @@index([farmId])
  @@index([cropCycleId])
}

model AgroTraceabilityEvent {
  id                String              @id @default(cuid())
  farmId            String
  farm              AgroFarm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  productionCycleId String?
  productionCycle   AgroProductionCycle? @relation(fields: [productionCycleId], references: [id], onDelete: SetNull)
  entityType        String              // AgroAnimal | AgroCropCycle | AgroInventoryItem
  entityId          String
  eventType         String              // ORIGIN | TRANSFER | TREATMENT | HARVEST | PROCESSING | SALE
  description       String
  occurredAt        DateTime
  latitude          Decimal?
  longitude         Decimal?
  evidenceUrls      Json?               // string[]
  verifiedBy        String?
  createdAt         DateTime            @default(now())

  @@index([farmId])
  @@index([entityType, entityId])
  @@index([productionCycleId])
}

model AgroComplianceCheck {
  id            String    @id @default(cuid())
  farmId        String
  farm          AgroFarm  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  checkType     String    // VACCINATION_RECORD | PESTICIDE_WITHDRAWAL | WATER_QUALITY | SANITARY_CERT | CUSTOM
  entityType    String?
  entityId      String?
  status        String    @default("PENDING") // PENDING | COMPLIANT | NON_COMPLIANT | WAIVED
  dueDate       DateTime?
  completedAt   DateTime?
  notes         String?
  evidenceUrls  Json?
  reviewedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([farmId, status])
  @@index([farmId, checkType])
}

// ── SPEC-AUT-001 — Permanent Loops v1 (ADR-021 §4.4) ─────────────────────────
// Memoria episódica de decisiones de agentes: qué decidió el loop X sobre el
// target Y y por qué. Los loops consultan rechazos previos antes de proponer.

model AgentDecision {
  id         String   @id @default(cuid())
  loopId     String?
  runId      String?
  agentType  String
  target     String
  kind       String   @default("finding") // finding | proposal | rejection
  decision   String   // recorded | proposed | accepted | rejected | suppressed
  rationale  String   @db.Text
  outcome    String?  // pending_review | merged | dismissed | expired
  confidence Float?
  evidence   Json?
  createdAt  DateTime @default(now())

  @@index([loopId, target])
  @@index([agentType, createdAt])
  @@index([decision, createdAt])
}

model PermanentLoopState {
  id               String    @id // loop id, ej. "loop.spec-drift"
  paused           Boolean   @default(false)
  pausedAt         DateTime?
  pausedBy         String?
  lastCycleAt      DateTime?
  lastCycleStatus  String?
  cyclesCompleted  Int       @default(0)
  cyclesSkipped    Int       @default(0)
  findingsRecorded Int       @default(0)
  proposalsOpened  Int       @default(0)
  tokensConsumed   Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ── Governance Sandbox — P4/P5 Prometeo DAO ───────────────────────────────────
// Reputation-weighted proposals, quadratic voting, participation credits.
// Tables created by migration 20260525000000_governance_sandbox.

model GovernanceProposal {
  id                    String   @id @default(cuid())
  tenantId              String
  title                 String
  description           String
  category              String   @default("general")
  status                String   @default("open")
  authorId              String
  authorReputationScore Decimal  @default(0) @db.Decimal(6, 2)
  mcaAdvice             String?
  mcaRisk               String   @default("low")
  closesAt              DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  votes GovernanceVote[]

  @@index([tenantId, status])
  @@index([tenantId, closesAt])
  @@index([authorId])
}

model GovernanceVote {
  id                   String   @id @default(cuid())
  tenantId             String
  proposalId           String
  proposal             GovernanceProposal @relation(fields: [proposalId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  voterId              String
  choice               String
  voterReputationScore Decimal  @default(0) @db.Decimal(6, 2)
  units                Int      @default(1)
  reason               String?
  createdAt            DateTime @default(now())

  @@unique([proposalId, voterId])
  @@index([tenantId, proposalId])
  @@index([voterId])
}

model GovernanceCreditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  eventType String
  credits   Decimal  @db.Decimal(8, 2)
  context   String   @default("{}")
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
  @@index([userId, createdAt])
}
