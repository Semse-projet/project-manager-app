  @@index([trade, createdAt])
  @@index([userId])
  @@index([jobId])
  @@index([buildOpsProjectId])
  @@index([createdAt])
}

/// Per-milestone evidence requirement tracking (before/during/after).
model MilestoneEvidenceItem {
