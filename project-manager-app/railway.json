{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "dockerfile",
    "context": ".",
    "dockerfilePath": "Dockerfile.api"
  },
  "deploy": {
    "restartPolicyType": "always",
    "restartPolicyMaxRetries": 5,
    "healthcheckPath": "/v1/health",
    "healthcheckTimeout": 300
  }
}
