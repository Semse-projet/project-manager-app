# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/semse_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=your_secret_here_min_32_chars

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── LLM Providers (at least ANTHROPIC for Prometeo to work) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
KIMI_API_KEY=...
ENABLE_OPEN_SOURCE_MODELS=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.semseproject.com,https://semseproject.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=50
