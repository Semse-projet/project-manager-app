# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
SEMSE_API_BASE_URL=http://localhost:4000
SEMSE_WEB_BASE_URL=http://localhost:3000
SEMSE_DEMO_MODE=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/semse_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=your_secret_here_min_32_chars

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
# Keep OFF until the domain-event worker/consumer slice (F1-D) is deployed.
SEMSE_EVENT_OUTBOX_DISPATCH_ENABLED=false
SEMSE_EVENT_OUTBOX_POLL_MS=1000
SEMSE_EVENT_OUTBOX_BATCH_SIZE=50
SEMSE_EVENT_OUTBOX_LEASE_MS=30000

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
SEMSE_STORAGE_ROOT=/tmp/semse-storage
SEMSE_MULTIPART_STORAGE_ROOT=/tmp/semse-storage/multipart

# ── LLM Router ────────────────────────────────────────────────────────────────
ENABLE_LLM_ROUTER=true

# Inteligencia nativa/local (Ollama) — local-first por defecto.
# Ollama es el provider principal. Anthropic/OpenAI son externos/fallback.
#
# Modelos disponibles (instalar con `ollama pull <modelo>`):
#   qwen2.5:0.5b  → 397 MB  — rápido para iterar (~4s warm en CPU)
#   qwen2.5:3b    → 1.9 GB  — recomendado para JSON estructurado y flujos reales
#   llama3.2:1b   → 1.3 GB  — alternativa ligera
#
# Timeout recomendado por hardware:
#   CPU sin GPU → OLLAMA_TIMEOUT_MS=120000  (3b tarda ~85s en primera carga, ~16s warm)
#   GPU         → OLLAMA_TIMEOUT_MS=30000   (primera carga <5s, warm <1s)
#   Iteración rápida sin GPU → usar qwen2.5:0.5b con 60000
#
LLM_NATIVE_PROVIDER=ollama
LLM_DEFAULT_PROVIDER=ollama
LLM_FALLBACK_PROVIDERS=anthropic,openai,template
LLM_EXTERNAL_FALLBACK_PROVIDER=anthropic

ENABLE_OPEN_SOURCE_MODELS=true
# ── Local development ──────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# ── Railway (mismo proyecto — red interna privada, sin auth) ──────────────────
# OLLAMA_BASE_URL=http://ollama.railway.internal:11434
# ── VPS externo con protección ────────────────────────────────────────────────
# OLLAMA_BASE_URL=https://ollama.tudominio.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_MODEL=qwen2.5:0.5b  # alternativa para Railway CPU (más rápido, menor RAM)
OLLAMA_TIMEOUT_MS=120000      # Railway CPU: 120s | GPU: 30s | local warm: 60s
OLLAMA_HEALTH_TIMEOUT_MS=5000
# OLLAMA_API_KEY=<token>      # Solo si VPS externo. Railway interno no necesita auth.

# Autonomy LLM (puede apuntar a modelo más ligero)
SEMSE_AUTONOMY_LLM_PROVIDER=ollama
SEMSE_AUTONOMY_LLM_BASE_URL=http://localhost:11434/v1
SEMSE_AUTONOMY_LLM_MODEL=llama3.2:1b
SEMSE_AUTONOMY_REPO_PATH=/path/to/project-manager-app
SEMSE_AUTONOMY_BASE_BRANCH=main
SEMSE_AUTONOMY_LOCAL_PR_MODE=true
SEMSE_RUNTIME_MODE=local

# ── LLM Externos (fallback / premium / tool calling) ──────────────────────────
# Usados cuando: requiresTools=true, riskLevel=high, o Ollama falla.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
KIMI_API_KEY=...
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=kimi-k2

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.semseproject.com,https://semseproject.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=50

# ── Communications ────────────────────────────────────────────────────────────
SEMSE_COMMUNICATIONS_MODE=mock
SEMSE_COMMUNICATIONS_NOTIFICATION_WHATSAPP=false
SEMSE_COMMUNICATIONS_TENANT_ID=tenant_default
SEMSE_COMMUNICATIONS_ORG_ID=org_admin_001
SEMSE_COMMUNICATIONS_ACTOR_USER_ID=usr_admin_001
WHATSAPP_CLOUD_API_VERSION=v20.0
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
