{
  "name": "@semse/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:unit": "node --experimental-strip-types --test test/**/*.test.ts",
    "test:coverage": "node ../../node_modules/c8/bin/c8.js --reporter=text --reporter=text-summary --reporter=html --reporter=lcov --reporter=json-summary --include=src/**/*.ts --exclude=test/**/*.test.ts --exclude=**/*.d.ts --check-coverage --lines 90 --functions 85 --branches 85 --statements 90 node --experimental-strip-types --test test/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/static": "^8.3.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.4.0",
    "@semse/agents": "workspace:*",
    "@semse/auth": "workspace:*",
    "@semse/autonomy": "workspace:*",
    "@semse/db": "workspace:*",
    "@semse/knowledge": "workspace:*",
    "@semse/schemas": "workspace:*",
    "@semse/shared": "workspace:*",
    "@types/pdfkit": "^0.17.6",
    "bullmq": "^5.50.1",
    "ioredis": "^5.4.2",
    "openai": "^6.34.0",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.2",
    "stripe": "^22.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
