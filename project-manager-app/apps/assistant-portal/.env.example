# assistant-portal (Vite + Express + tRPC + Drizzle)
# Este app usa su propio stack (MySQL vía Drizzle), independiente del Postgres/Prisma
# del resto del monorepo. DATABASE_URL aqui es MySQL, no confundir con el DATABASE_URL
# de apps/api.

# MySQL connection string, e.g. mysql://user:password@host:3306/assistant_portal
DATABASE_URL=

# Session/cookie signing
JWT_SECRET=
ENCRYPTION_KEY=

# Google OAuth (login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Stripe (billing) — separado de la integración Stripe de apps/api
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Heredado de la plataforma original donde se generó este prototipo ---
# Estas variables apuntan a un backend de auth/IA propietario (probablemente un
# builder tipo Manus, ver `vite-plugin-manus-runtime` en devDependencies).
# Las features de IA (generador de docs, análisis de código) NO funcionarán
# fuera de esa plataforma hasta reemplazar estas llamadas por una API key
# directa de Anthropic/OpenAI. Ver plan de Fase 2.
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
