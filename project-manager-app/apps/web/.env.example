# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── API connection ────────────────────────────────────────────────────────────
# NOTE: Set as Railway Service Variable (runtime), NOT as build arg
# Internal Railway URL (faster): http://semse-api.railway.internal:4000
# External URL: https://semse-api-xxxx.railway.app
SEMSE_API_BASE_URL=http://semse-api.railway.internal:4000

# ── Auth (Session Middleware) ─────────────────────────────────────────────────
# NOTE: Set as Railway Service Variable (runtime)
# Generate: openssl rand -hex 32
AUTH_SECRET=your_secret_here_min_32_chars_for_session_middleware

# ── Bootstrap Token (Worker-to-API auth) ──────────────────────────────────────
# NOTE: Set as Railway Service Variable (runtime)
# Used by worker and internal services to authenticate to API
SEMSE_BOOTSTRAP_TOKEN=your_bootstrap_token_here

# ── Default session (override per-request via cookies) ───────────────────────
# These are demo defaults; override via cookies in production
SEMSE_TENANT_ID=tenant_default
SEMSE_ORG_ID=org_admin_001
SEMSE_USER_ID=usr_admin_001
SEMSE_ROLES=OPS_ADMIN

# ── Feature flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SEMSE_RUNTIME_ENABLED=true
NEXT_PUBLIC_SEMSE_DEMO_LOGIN_ENABLED=false
