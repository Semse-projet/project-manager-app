# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── API connection ────────────────────────────────────────────────────────────
# Internal Railway URL (faster): https://semse-api.railway.internal
# External URL: https://semse-api-xxxx.railway.app
SEMSE_API_BASE_URL=https://semse-api-xxxx.railway.app

# ── Default session (override per-request via cookies) ───────────────────────
SEMSE_TENANT_ID=tenant_default
SEMSE_ORG_ID=org_admin_001
SEMSE_USER_ID=usr_admin_001
SEMSE_ROLES=OPS_ADMIN

# ── Feature flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SEMSE_RUNTIME_ENABLED=true
