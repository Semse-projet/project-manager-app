{
  "name": "project-manager-app",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:ci": "npm run test:coverage && npm run test:e2e",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "coverage": "npm run test:coverage",
    "test:coverage": "c8 --reporter=text --reporter=text-summary --reporter=html --reporter=lcov --reporter=json-summary --include=logic.mjs --check-coverage --lines 90 --functions 90 --branches 85 --statements 90 node --test tests/unit/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "release:patch": "npm version patch -m \"chore(release): %s\"",
    "release:minor": "npm version minor -m \"chore(release): %s\"",
    "release:major": "npm version major -m \"chore(release): %s\""
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "c8": "^10.1.3"
  }
}
